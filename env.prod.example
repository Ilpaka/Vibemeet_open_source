# Vibemeet - production environment template.
# Copy to .env.prod and replace every value. Never commit the result.
#
#   cp env.prod.example .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# --- Required -------------------------------------------------------------

# Public IP/hostname of the server (used by LiveKit for ICE candidates
# and by the frontend to build the WebRTC URL).
HOST_IP=

# WebSocket URL the frontend uses to reach LiveKit.
# Format: ws://HOST:17880 (or wss://HOST:17880 behind TLS).
LIVEKIT_FRONTEND_URL=

# Database
POSTGRES_DB=vibemeet
POSTGRES_USER=vibemeet
POSTGRES_PASSWORD=

# JWT secrets - generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# LiveKit credentials (shared with the LiveKit container)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Optional -------------------------------------------------------------

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
LIVEKIT_PORT=17880
HTTP_PORT=18080
HTTPS_PORT=18443
LOG_LEVEL=info

# Set to false to manage migrations out-of-band via `vibemeet migrate up`.
MIGRATE_ON_BOOT=true
