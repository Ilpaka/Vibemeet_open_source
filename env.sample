# Vibemeet — development environment template.
# Copy to .env and adjust values: cp env.sample .env

# --- Runtime --------------------------------------------------------------
ENVIRONMENT=development
SERVER_PORT=8081
NGINX_PORT=80
LOG_LEVEL=info

# --- PostgreSQL -----------------------------------------------------------
POSTGRES_DB=vibemeet
POSTGRES_USER=vibemeet
POSTGRES_PASSWORD=vibemeetpass
POSTGRES_PORT=5432

# --- Redis ----------------------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ------------------------------------------------------------------
# Generate strong secrets for production: `openssl rand -hex 32`
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# --- LiveKit (media server) ----------------------------------------------
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# LAN access (mobile ↔ desktop on the same WiFi).
# Leave empty for localhost-only; otherwise set to your machine's LAN IP.
HOST_IP=
